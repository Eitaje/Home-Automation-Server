# Copy this file to .env and fill in your values.
# Do NOT put inline comments on value lines — dotenv does not support them.

# Redis (leave as-is when using docker-compose; use localhost:6379 for local dev)
REDIS_URL=redis://localhost:6379

# Where Redis stores its data on the host filesystem (bind mount).
# Local dev: leave empty — defaults to ./redis-data next to docker-compose.yml
# TrueNAS:   set to your dataset path, e.g. /mnt/pool/homeauto/redis-data
REDIS_DATA_PATH=

# NodeMCU sensor node
NODEMCU_IP=192.168.1.X
# Seconds between polls
NODEMCU_POLL_INTERVAL=10
# Leave empty if the endpoint has no auth
NODEMCU_AUTH_USER=
NODEMCU_AUTH_PASSWORD=

# How many readings to keep per device stream in Redis
STREAM_MAX_LEN=10000
